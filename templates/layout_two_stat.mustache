{{!
    @template block_dash/layout_two_stat

    Example context (json):
    {
        "sitefullname": "Moodle - 311",
		"courseurl": "https://localhost/moodle/course/view.php?id=2"
    }
}}
{{< block_dash/layout }}
    {{$body}}
        {{#data.first_child}}
            {{#first_data}}
                <h3 class="text-center">{{{stat}}} / {{{other_stat}}} <small style="font-size:0.5em">{{preferences.stat_field_label}}</small></h3>
            {{/first_data}}
        {{/data.first_child}}
    {{/body}}
{{/ block_dash/layout }}
